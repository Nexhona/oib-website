# OiB Kontaktformular — SMTP-Konfiguration
#
# Solange diese Datei fehlt oder leer ist, werden Nachrichten NUR gespeichert
# (lesbar via:  /home/neo/oib/contact/venv/bin/python /home/neo/oib/contact/nachrichten.py ).
# Sobald hier gültige SMTP-Zugangsdaten stehen und der Dienst neu gestartet wird,
# werden alle Anfragen ZUSÄTZLICH per Mail an MAIL_TO geschickt — KEIN Code-Change nötig.
#
# Diese Datei nach Eintragen umbenennen/kopieren zu:  /home/neo/oib/contact/.env
# und dann:  sudo systemctl restart oib-contact
#
# --- Beispiel für ein typisches Postfach (info@o-i-b.ch beim Hoster) ---
SMTP_HOST=mail.example-hoster.ch
SMTP_PORT=587
SMTP_USER=info@o-i-b.ch
SMTP_PASS=DEIN_PASSWORT_HIER
# SMTP_SSL=1            # nur setzen wenn der Hoster Port 465 (implizites TLS) verlangt
MAIL_TO=info@o-i-b.ch
MAIL_FROM=info@o-i-b.ch
